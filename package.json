{
  "name": "semantic-workspace",
  "version": "0.1.0",
  "description": "Render semantic development workspaces into tmux",
  "private": true,
  "type": "module",

  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },

  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  }
}